# ── Server ───────────────────────────────────────────
PORT=8080
GIN_MODE=debug        # set to "release" in production

# ── FusionAuth (self-hosted) ─────────────────────────
# Base URL of your running FusionAuth instance
FUSIONAUTH_URL=http://localhost:9011
# JWT issuer must match the "issuer" field in FusionAuth Tenant settings (Tenants > Edit > General > Issuer)
# Check: curl http://localhost:9011/{tenantId}/.well-known/openid-configuration | grep issuer
JWT_ISSUER=localhost:9011

# From FusionAuth: Settings > API Keys
FUSIONAUTH_API_KEY=your-fusionauth-api-key

# From FusionAuth: Applications > your app > OAuth > Client ID/Secret
FUSIONAUTH_CLIENT_ID=your-client-id
FUSIONAUTH_CLIENT_SECRET=your-client-secret

# Must match exactly what you registered in FusionAuth's Authorized Redirect URLs
REDIRECT_URL=http://localhost:8080/auth/callback

# ── Session ──────────────────────────────────────────
SESSION_SECRET=change-this-to-a-long-random-string

# ── CORS / Frontend ───────────────────────────────────
FRONTEND_URL=http://localhost:5173
